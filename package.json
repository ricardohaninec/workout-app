{
  "name": "workout-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "build": "next build --webpack",
    "start": "next start --port 3000",
    "lint": "eslint . --max-warnings 0",
    "db:init": "bun scripts/init-db.ts",
    "db:migrate": "bun scripts/migrate-workout-items.ts",
    "db:test": "bun scripts/test-db.ts",
    "db:migrate-wip": "bun scripts/migrate-workout-in-progress.ts",
    "db:migrate-item-note": "bun scripts/migrate-add-item-note.ts",
    "db:migrate-set-complete": "bun scripts/migrate-add-set-complete.ts",
    "db:migrate-rest-seconds": "bun scripts/migrate-add-rest-seconds.ts",
    "db:migrate-diet": "bun scripts/migrate-add-diet.ts",
    "db:migrate-wip-cascade": "bun --env-file=.env.local scripts/migrate-workout-in-progress-set-cascade.ts",
    "db:seed": "bun scripts/seed.ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@base-ui/react": "^1.2.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@serwist/next": "^9.5.7",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@vercel/blob": "^2.3.1",
    "better-auth": "^1.5.4",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "bun-types": "^1.3.10",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.1",
    "serwist": "^9.5.7",
    "shadcn": "^4.0.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "better-sqlite3",
    "sharp",
    "unrs-resolver"
